{
  "version": "1.0",
  "name": "customers-search",
  "func_name": "CustomersSearch::CustomersSearch.Function::FunctionHandler",
  "resource_type": "lambda",
  "iam_role_name": "customers-search-role",
  "runtime": "dotnet8",
  "memory": 256,
  "timeout": 100,
  "lambda_path": "lambdas\\customers-search",
  "dependencies": [
    {
      "resource_name": "Users",
      "resource_type": "dynamodb_table"
    },
    {
      "resource_name": "waiters-list",
      "resource_type": "dynamodb_table"
    }
  ],
  "event_sources": [],
  "env_variables": {
    "USERS_TABLE": "Users",
    "WAITERS_TABLE": "waiters-list"
  },
  "publish_version": true,
  "alias": "${lambdas_alias_name}",
  "url_config": {},
  "ephemeral_storage": 512,
  "tags": {}
}
