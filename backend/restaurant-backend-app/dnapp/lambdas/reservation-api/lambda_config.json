{
  "version": "1.0",
  "name": "reservation-api",
  "func_name": "ReservationApi::ReservationApi.Function::FunctionHandler",
  "resource_type": "lambda",
  "iam_role_name": "reservation-api-role",
  "runtime": "dotnet8",
  "memory": 256,
  "timeout": 100,
  "lambda_path": "lambdas\\reservation-api",
  "dependencies": [
    {
      "resource_name": "Reservations",
      "resource_type": "dynamodb_table"
    },
    {
      "resource_name": "Tables",
      "resource_type": "dynamodb_table"
    },
    {
      "resource_name": "BookingLocks",
      "resource_type": "dynamodb_table"
    }
  ],
  "event_sources": [],
  "env_variables": {
    "RESERVATIONS_TABLE": "Reservations",
    "TABLES_TABLE": "Tables",
    "BOOKING_LOCKS_TABLE": "BookingLocks"
  },
  "publish_version": true,
  "alias": "${lambdas_alias_name}",
  "url_config": {},
  "ephemeral_storage": 512,
  "tags": {}
}